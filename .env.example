# Copy to .env and fill in. Do not commit .env.

# API server port
PORT=8080

# Database (default for docker-compose postgres)
DATABASE_URL=postgres://vroom:vroom@localhost:5432/vroom?sslmode=disable

# NATS (default for docker-compose nats)
NATS_URL=nats://localhost:4222

# JWT signing secret (generate a random string for production)
JWT_SECRET=your-secret-at-least-32-chars-long
